<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="021-add-product-fields-to-sales" author="billbharat">
        <addColumn tableName="sales">
            <column name="product_id" type="UUID"/>
            <column name="product_name" type="VARCHAR(255)"/>
            <column name="product_price" type="DECIMAL(12,2)"/>
            <column name="has_commission" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="commission_amount" type="DECIMAL(12,2)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
