<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="011-create-achievements" author="billbharat">
        <createTable tableName="user_achievements">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="badge_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="unlocked_at" type="TIMESTAMP"/>
            <column name="points_earned" type="INTEGER" defaultValueNumeric="0"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createIndex tableName="user_achievements" indexName="idx_achievement_user">
            <column name="user_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
