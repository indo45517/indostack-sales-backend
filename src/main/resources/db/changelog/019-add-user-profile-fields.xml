<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="019-add-user-profile-fields" author="billbharat">
        <addColumn tableName="users">
            <column name="territory" type="VARCHAR(100)"/>
            <column name="target" type="DECIMAL(14,2)"/>
            <column name="commission_rate" type="DECIMAL(5,2)"/>
            <column name="join_date" type="DATE"/>
            <column name="daily_visit_target" type="INT"/>
            <column name="daily_demo_target" type="INT"/>
            <column name="daily_delivery_target" type="INT"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
